{
  "type": "object",
  "properties": {
    "project_name": {
      "type": "string"
    },
    "wbs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "phase": {
            "type": "string"
          },
          "tasks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "phase",
          "tasks"
        ]
      }
    },
    "gantt_data": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "task_name": {
            "type": "string"
          },
          "duration_days": {
            "type": "integer"
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "task_name",
          "duration_days",
          "dependencies"
        ]
      }
    },
    "risk_log": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "risk": {
            "type": "string"
          },
          "probability": {
            "type": "string",
            "enum": [
              "Low",
              "Medium",
              "High"
            ]
          },
          "impact": {
            "type": "string",
            "enum": [
              "Low",
              "Medium",
              "High"
            ]
          },
          "mitigation": {
            "type": "string"
          }
        },
        "required": [
          "risk",
          "probability",
          "impact",
          "mitigation"
        ]
      }
    }
  },
  "required": [
    "project_name",
    "wbs",
    "gantt_data",
    "risk_log"
  ]
}